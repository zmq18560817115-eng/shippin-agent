{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "render_report",
  "type": "object",
  "required": ["version", "project_id", "output_path", "ffprobe"],
  "properties": {
    "version": {"const": "2.0"},
    "project_id": {"type": "string"},
    "output_path": {"type": "string", "minLength": 1},
    "ffprobe": {
      "type": "object",
      "required": ["duration", "resolution", "fps", "audio_streams"],
      "properties": {
        "duration": {"type": "number", "minimum": 0},
        "resolution": {"type": "string", "pattern": "^\\d+x\\d+$"},
        "fps": {"type": "number", "minimum": 0},
        "audio_streams": {"type": "integer", "minimum": 0}
      }
    }
  }
}
