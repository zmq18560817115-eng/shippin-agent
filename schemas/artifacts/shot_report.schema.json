{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "shot_report",
  "type": "object",
  "required": ["version", "project_id", "shots"],
  "properties": {
    "version": {"const": "2.0"},
    "project_id": {"type": "string"},
    "shots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "status", "attempt"],
        "properties": {
          "number": {"type": "integer", "minimum": 1},
          "status": {"enum": ["queued", "running", "succeeded", "failed", "blocked"]},
          "path": {"type": "string"},
          "cost_cny": {"type": "number", "minimum": 0},
          "attempt": {"type": "integer", "minimum": 0},
          "duration_sec": {"type": "number", "minimum": 1, "maximum": 15},
          "error": {"type": "object"}
        }
      }
    }
  }
}
