{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "asset_manifest",
  "type": "object",
  "required": ["version", "project_id", "product_id", "seedance_source", "hero_frames"],
  "properties": {
    "version": {"const": "2.0"},
    "project_id": {"type": "string"},
    "product_id": {"type": "string"},
    "identity_mode": {"enum": ["product_reference", "prompt_only"]},
    "seedance_source": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "character_assets": {"type": "array", "items": {"type": "string"}},
    "hero_frames": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["number", "path"],
        "properties": {
          "number": {"type": "integer", "minimum": 1},
          "path": {"type": "string", "minLength": 1},
          "source_refs": {"type": "array", "items": {"type": "string"}},
          "status": {"enum": ["generated", "approved", "needs_review", "blocked"]}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"identity_mode": {"const": "prompt_only"}}, "required": ["identity_mode"]},
      "then": {
        "properties": {
          "seedance_source": {"maxLength": 0},
          "hero_frames": {"maxItems": 0}
        }
      },
      "else": {
        "properties": {
          "seedance_source": {"minLength": 1},
          "hero_frames": {"minItems": 1}
        }
      }
    }
  ]
}
