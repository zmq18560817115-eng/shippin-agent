{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "asset_manifest",
  "type": "object",
  "required": ["version", "project_id", "product_id", "seedance_source", "hero_frames"],
  "properties": {
    "version": {"const": "2.0"},
    "project_id": {"type": "string"},
    "product_id": {"type": "string"},
    "seedance_source": {"type": "string", "minLength": 1},
    "character_assets": {"type": "array", "items": {"type": "string"}},
    "hero_frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["number", "path"],
        "properties": {
          "number": {"type": "integer", "minimum": 1},
          "path": {"type": "string", "minLength": 1},
          "source_refs": {"type": "array", "items": {"type": "string"}},
          "status": {"enum": ["generated", "approved", "needs_review", "blocked"]}
        }
      }
    }
  }
}
