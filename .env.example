# Copy to .env.local and fill locally. Never commit real credentials.
DOUBAO_API_KEY=
SEEDANCE_API_KEY=
# Optional real ASR. New console uses API_KEY only; old console uses APP_KEY + ACCESS_KEY.
VOLCENGINE_ASR_API_KEY=
VOLCENGINE_ASR_APP_KEY=
VOLCENGINE_ASR_ACCESS_KEY=
# Offline fallback for subtitle-free videos. The model is downloaded once and cached.
VAF_LOCAL_ASR_ENABLED=false
VAF_LOCAL_ASR_MODEL=base
VAF_LOCAL_ASR_DEVICE=cpu
VAF_LOCAL_ASR_COMPUTE_TYPE=int8
VAF_LOCAL_ASR_CACHE_DIR=
VAF_TESSERACT_CMD=
# Optional mirror for networks that cannot reach huggingface.co.
HF_ENDPOINT=
APIFY_API_TOKEN=
TIKTOK_MS_TOKEN=
TIKTOK_BROWSER=chromium
TIKTOK_HEADLESS=true
TIKTOK_BROWSER_SEARCH_BROWSER=chromium
TIKTOK_SEARCH_WAIT_MS=12000
TIKTOK_BROWSER_SEARCH_TIMEOUT_SEC=90
TIKTOK_BROWSER_SEARCH_RETRIES=3
TIKTOK_DOWNLOAD_TIMEOUT_SEC=120
TIKTOK_SEARCH_CACHE_PATH=data/runtime/tiktok-search-cache.json
TIKTOK_SEARCH_CACHE_MAX_AGE_SEC=86400
VAF_TIKTOK_ENRICH_LIMIT=12
TIKTOK_TIMEOUT_MS=45000
VAF_TIKTOK_METADATA_TIMEOUT_S=15
VAF_TIKTOK_ENRICH_LIMIT=5
TIKTOK_WORKER_TIMEOUT_SEC=75
TIKTOK_PROXY=
# Production intake gates. Candidates below either observed threshold are not downloaded.
VAF_TIKTOK_MIN_RELEVANCE=0.50
VAF_TIKTOK_MIN_PLAYS=5000
# Recommended on headless intranet servers when TikTok blocks anonymous yt-dlp.
# Export a dedicated service account cookie file; never commit it.
TIKTOK_COOKIES_FILE=
# Local-only fallback, for example chromium or chromium:Default.
TIKTOK_COOKIES_BROWSER=

# Optional model overrides.
ARK_DOUBAO_MODEL=
ARK_SEEDANCE_MODEL=
# Per-request read timeout for Ark calls. Reasoning models can take a few
# minutes to return a large script/shot-plan JSON; raise this if real runs
# fail with "read operation timed out". Defaults to 240s when unset.
ARK_TIMEOUT_S=300
SEEDANCE_MAX_WAIT_S=900
# Optional CA bundle for egress proxies that terminate TLS (keeps verification
# on). Falls back to SSL_CERT_FILE / REQUESTS_CA_BUNDLE, then the system store.
ARK_CA_BUNDLE=

# Per-call internal CNY estimates used by the enforce budget gate. Update these
# from the enterprise invoice; they are not a replacement for provider billing.
VAF_PRICE_DOUBAO_ANALYZE_CNY=0.093
VAF_PRICE_DOUBAO_SCRIPT_CNY=0.119
VAF_PRICE_DOUBAO_SHOTPLAN_CNY=0.082
VAF_PRICE_DOUBAO_REVIEW_CNY=0.033
VAF_PRICE_SEEDANCE_SHOT_CNY=5.96
VAF_PRICE_FFMPEG_COMPOSE_CNY=0.0

# Persistent TikTok collection jobs are consumed in the API background process.
# Set false only when a dedicated collection worker process owns the queue.
VAF_COLLECTION_WORKER_ENABLED=true
# Terminal task cards are cleaned automatically. Imported material files and
# material-library records are retained; only queue jobs and temporary candidates expire.
VAF_COLLECTION_CLEANUP_ENABLED=true
VAF_COLLECTION_CLEANUP_INTERVAL_SECONDS=3600
VAF_COLLECTION_SUCCEEDED_RETENTION_DAYS=7
VAF_COLLECTION_FAILED_RETENTION_DAYS=14

VAF_HOST=127.0.0.1
VAF_PORT=8790
# Optional deployment identifier shown in the admin service-status panel.
# CI/CD may set this to the deployed Git commit SHA.
VAF_BUILD_VERSION=
VAF_PRODUCT_ID=便携恒温杯

# Optional background discovery. Keep disabled until a target and review cadence are confirmed.
VAF_AUTO_COLLECT_ENABLED=false
VAF_AUTO_COLLECT_TARGET_TYPE=keyword
VAF_AUTO_COLLECT_TARGET=
VAF_AUTO_COLLECT_PROVIDER=auto
VAF_AUTO_COLLECT_LIMIT=3
VAF_AUTO_COLLECT_INTERVAL_MINUTES=60
# true executes real download and analysis; false keeps the background collector in mock mode.
VAF_AUTO_COLLECT_REAL=false

# Intranet login. These are bootstrap accounts created into SQLite at first startup.
# Manage subsequent members in the admin portal instead of sharing these credentials.
VAF_AUTH_ENABLED=false
VAF_SELF_REGISTRATION_ENABLED=true
VAF_SESSION_SECRET=
VAF_OPERATOR_USER=
VAF_OPERATOR_PASSWORD=
VAF_ADMIN_USER=
VAF_ADMIN_PASSWORD=
VAF_COOKIE_SECURE=false
# In intranet HTTPS deployment set this to true. false is only for local HTTP debugging.
